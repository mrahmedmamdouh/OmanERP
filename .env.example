# ═══════════════════════════════════════════════════════════
# OMAN SME ERP — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# Server
NODE_ENV=production
PORT=3001

# Database (PostgreSQL)
# Supabase: Settings > Database > Connection String
# Railway: auto-provided
# Neon: Dashboard > Connection Details
DATABASE_URL=postgresql://user:password@host:5432/oman_erp?sslmode=require

# Auth
JWT_SECRET=your-secret-key-minimum-32-chars-change-this
JWT_EXPIRES_IN=24h

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Optional: Email (for invoice sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
